PORT=3000

# Shopify
SHOPIFY_WEBHOOK_SECRET=replace_with_shopify_webhook_secret

# WhatsApp Cloud API (Meta)
WHATSAPP_GRAPH_VERSION=v24.0
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_ACCESS_TOKEN=replace_with_access_token
WHATSAPP_TEMPLATE_NAME=review_request
WHATSAPP_TEMPLATE_LANGUAGE=es
# false = sends the review link as body variable {{3}}
# true = sends only {{1}} name and {{2}} product, plus a dynamic URL button parameter.
WHATSAPP_REVIEW_LINK_IN_BUTTON=false
DEFAULT_COUNTRY_CODE=507

# Judge.me
# Use the all-products review link from Judge.me > Settings > Request reviews > Links, QR codes...
# The automation will add the purchased Shopify product ID to this base link when possible.
JUDGEME_REVIEW_LINK=https://judge.me/product_reviews/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/new?source=shareable-link

# Timing
SEND_DELAY_DAYS=7

# Optional: only send if the order has at least one fulfilled item.
REQUIRE_FULFILLED_ITEMS=true

# If the order has several products, send the customer to the first fulfilled product.
# Set to false to always use the general Judge.me link instead.
PERSONALIZE_LINK_BY_PRODUCT=true

# Abandoned checkout WhatsApp recovery
PUBLIC_APP_URL=https://your-app.ondigitalocean.app
ABANDONED_CHECKOUT_ENABLED=true
ABANDONED_CHECKOUT_FIRST_DELAY_MINUTES=20
ABANDONED_CHECKOUT_SECOND_ENABLED=true
ABANDONED_CHECKOUT_SECOND_DELAY_HOURS=24
ABANDONED_CHECKOUT_TEMPLATE_NAME=checkout_abandonado
ABANDONED_CHECKOUT_SECOND_TEMPLATE_NAME=checkout_abandonado
ABANDONED_CHECKOUT_TEMPLATE_LANGUAGE=es
ABANDONED_CHECKOUT_LINK_IN_BUTTON=true
